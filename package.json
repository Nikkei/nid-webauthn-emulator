{
  "name": "nid-webauthn-emulator",
  "version": "0.2.15",
  "keywords": [
    "test",
    "e2e",
    "passkeys"
  ],
  "repository": "https://github.com/Nikkei/nid-webauthn-emulator.git",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist"
  ],
  "author": "Nikkei Inc.",
  "license": "MIT",
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "check": "biome check .",
    "test": "pnpm build && node --test --test-concurrency=4 \"dist/spec/**/*.spec.js\"",
    "test:webauthn-io": "pnpm build && RUN_WEBAUTHN_IO=1 node --test --test-name-pattern \"Registration Ceremony and Authentication Ceremony\" dist/spec/integration/integration.spec.js",
    "build": "tsc"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@simplewebauthn/server": "13.3.2",
    "@tsconfig/recommended": "1.0.13",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "tldts": "7.1.2"
  }
}
